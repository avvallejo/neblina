# Copia este archivo a .env y cambia TODAS las contraseñas antes de levantar
# el proyecto — los valores de aquí son solo para que el ejemplo se entienda.

# Puertos en tu máquina (cambia estos si otro proyecto ya usa 5432 o 3000;
# el puerto DE ADENTRO del contenedor no cambia, así que la API y la base de
# datos siguen hablándose igual sin que tengas que tocar nada más).
DB_HOST_PORT=5432
API_HOST_PORT=3000

# PostgreSQL
POSTGRES_SUPERUSER_PASSWORD=cambia_esta_contrasena_super
CAFETERIA_APP_PASSWORD=cambia_esta_otra_contrasena

# Genera uno real con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Dominio del frontend que puede llamar a la API. En producción, nunca "*".
CORS_ORIGIN=*

# SMS para verificar teléfono de clientes: "console" (no manda nada, solo
# imprime el código en los logs — para desarrollo) o "sns" (AWS SNS, real).
SMS_PROVIDER=console
SMS_COUNTRY_CODE=52
AWS_REGION=us-east-1
# Si usas SMS_PROVIDER=sns, además necesitas credenciales de AWS disponibles
# para el contenedor (variables AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY, o
# mejor, un rol de IAM si esto ya corre dentro de AWS).
