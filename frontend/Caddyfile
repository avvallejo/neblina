# El sitio se define por SITE_ADDRESS:
#  - Detrás del portero (servidor compartido): SITE_ADDRESS=:80  -> sirve HTTP
#    interno; el HTTPS lo pone el portero. (Es el valor por defecto.)
#  - Servidor DEDICADO (handoff al cliente): SITE_ADDRESS=tu-dominio -> Caddy
#    saca el certificado solo (publica 80/443 en el compose).
{
	email {$ACME_EMAIL}
}

{$SITE_ADDRESS::80} {
	encode zstd gzip

	# Las llamadas a la API van al contenedor de la API (api:3000 por defecto).
	# Si separas la API a otro servidor, cambia API_UPSTREAM y no se toca nada más.
	handle /api/* {
		reverse_proxy {$API_UPSTREAM:api:3000}
	}

	# El resto es la app de React (SPA): si la ruta no es un archivo real, se
	# devuelve index.html para que el ruteo del navegador funcione.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
