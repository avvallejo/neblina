# ============================================================================
# PRODUCCIÓN — copia este archivo a .env.prod EN EL SERVIDOR y cambia TODO.
# NUNCA subas .env.prod a git (está en .gitignore).
# ============================================================================

# Dominio público de la app y correo para el certificado HTTPS (Let's Encrypt).
DOMAIN=cafeteria.tudominio.com
ACME_EMAIL=tucorreo@dominio.com

# PostgreSQL (en Docker, en este servidor). Genera contraseñas largas y únicas.
POSTGRES_SUPERUSER_PASSWORD=cambia_esto_por_algo_largo
CAFETERIA_APP_PASSWORD=cambia_esto_por_algo_largo_distinto

# Secreto para firmar los tokens (JWT). Genera uno real con:
#   openssl rand -hex 48
JWT_SECRET=

# Solo el dominio de la app puede llamar a la API.
CORS_ORIGIN=https://cafeteria.tudominio.com

# SMS de verificación del cliente: "console" (gratis; el código va a los logs de
# la API) o "sns" (AWS SNS real; requiere credenciales/rol de AWS en el servidor).
SMS_PROVIDER=console
SMS_COUNTRY_CODE=52
AWS_REGION=us-east-1

# 2 para la topología compartida portero -> Caddy -> API.
# Usa 1 si Caddy recibe al cliente directamente. No lo dejes vacío.
TRUST_PROXY_HOPS=2

# --- Solo si algún día separas la base de datos a otro servidor / Amazon RDS ---
# Descomenta y apunta la API a la base externa, y quita el servicio "db" del
# docker-compose.prod.yml. (La contraseña sigue siendo CAFETERIA_APP_PASSWORD.)
# PGHOST=mi-instancia.xxxxxxxx.us-east-1.rds.amazonaws.com
# PGPORT=5432
# PGUSER=cafeteria_app
# PGDATABASE=cafeteria
